# =============================================================================
# NWK_AKASH Environment Configuration
# =============================================================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# =============================================================================

# ---- Database ----
# PostgreSQL connection string (Neon, Railway, or any managed Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/nwk?sslmode=require"

# ---- JWT Secrets ----
# REQUIRED. Each must be at least 32 random characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Access and refresh secrets MUST be different values.
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# ---- Application ----
NODE_ENV="development"
APP_URL="http://localhost:3000"
ALLOWED_HOSTS="localhost,127.0.0.1"
ALLOWED_ORIGINS="http://localhost:3000"

# ---- Proxy Trust ----
TRUST_PROXY="false"
PROXY_SHARED_SECRET=""

# ---- Request Limits ----
MAX_REQUEST_BODY_BYTES="26214400"

# ---- Redis (Optional — falls back to in-memory rate limiting) ----
# Upstash Redis URL for rate limiting (free tier: 10K commands/day)
# Use rediss:// (with double s) for Upstash TLS connections
REDIS_URL=""

# ---- File Uploads ----
STORAGE_PROVIDER="local"
UPLOAD_DIR="private-uploads"
MAX_UPLOAD_SIZE_MB="20"

# ---- Demo Seed ----
ALLOW_DEMO_SEED="false"

# ---- Bootstrap Admin ----
# ADMIN_EMAIL for single admin, ADMIN_EMAILS for multiple (comma-separated)
ADMIN_EMAIL=""
ADMIN_EMAILS=""
ADMIN_NAME="System Administrator"
ADMIN_INITIAL_PASSWORD=""
