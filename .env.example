# =============================================================================
# NWK_AKASH Environment Configuration
# =============================================================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# NEVER use development/demo secrets in production.
# =============================================================================

# ---- Database ----
# SQLite file path relative to the project root.
DATABASE_URL="file:./data/custom.db"

# ---- JWT Secrets ----
# REQUIRED. Each must be at least 32 random characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Access and refresh secrets MUST be different values.
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# ---- Application ----
NODE_ENV="development"
APP_URL="http://localhost:3000"
ALLOWED_HOSTS="localhost,127.0.0.1"
ALLOWED_ORIGINS="http://localhost:3000"

# ---- Proxy Trust ----
# Set to "true" when behind Caddy/reverse proxy.
# Requires PROXY_SHARED_SECRET to be set to the same value in Caddy.
TRUST_PROXY="false"
PROXY_SHARED_SECRET=""

# ---- Request Limits ----
MAX_REQUEST_BODY_BYTES="26214400"

# ---- Redis ----
REDIS_URL="redis://127.0.0.1:6379"

# ---- File Uploads ----
STORAGE_PROVIDER="local"
UPLOAD_DIR="private-uploads"
MAX_UPLOAD_SIZE_MB="20"

# ---- Demo Seed ----
# Only set to "true" in development. Never in production.
ALLOW_DEMO_SEED="false"

# ---- Bootstrap Admin ----
# Used only during initial setup via `npm run db:bootstrap-admin`.
# After first login, rotate this password immediately.
ADMIN_EMAIL=""
ADMIN_NAME="Admin"
ADMIN_INITIAL_PASSWORD=""
