# =============================================================================
# NWK_AKASH .gitignore
# =============================================================================

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo
local-*

# editor / AI
.claude
.z-ai-config
.vscode
.idea
*.swp
*.swo
*~

# logs
*.log
dev.log
dev.out.log
server.log

# databases
/db/*.db
/prisma/data/*.db
*.db
*.db-wal
*.db-shm

# uploads and private files
/private-uploads/
/upload/
/download/
/tool-results/
/release/
/test-results/
/.zscripts/*.pid
/worklog.md
/.codex_tmp/
/skills/

# archives and temporary
*.zip
*.tar.gz
*.tgz
/tmp/
/temp/

# docker
docker-compose.override.yml
