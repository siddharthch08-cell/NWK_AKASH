{
  "name": "nwk",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && node scripts/copy-standalone.mjs",
    "start": "node scripts/start-production.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/auth src/__tests__/admin src/__tests__/security src/__tests__/phase3 src/__tests__/phase2/domain-architecture.test.ts src/__tests__/phase2/workflow-regressions.test.ts",
    "test:integration": "vitest run src/__tests__/phase2/admin-student-flow.integration.test.ts",
    "test:concurrency": "vitest run src/__tests__/phase2/concurrency.integration.test.ts",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx scripts/seed.ts",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "security:history": "node scripts/scan-git-history.mjs",
    "security:credentials": "tsx scripts/audit-default-credentials.ts",
    "artifact:inspect": "node scripts/inspect-artifact.mjs",
    "db:check": "tsx scripts/check-database.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "geist": "^1.7.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "recharts": "^2.15.4",
    "redis": "^5.8.2",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
